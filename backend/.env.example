# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram, get the token
# Then send /start to your bot, and get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DGClaw (Degenerate Claw) — Direct ACP Executor (recommended)
# API key obtained via `dgclaw.sh join` — used for leaderboard/forum
DGCLAW_API_KEY=

# OpenClaw Agent Configuration (legacy — used when dgclaw.enabled=false)
# Local Gateway default: http://127.0.0.1:18789
OPENCLAW_ENDPOINT=http://127.0.0.1:18789
OPENCLAW_API_KEY=
