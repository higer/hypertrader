# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram, get the token
# Then send /start to your bot, and get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# DGClaw v4.0 — Direct Hyperliquid Trading
# ============================================================
# Trading now goes directly to Hyperliquid via API wallet.
# ACP is only used for USDC deposits and registration.

# Hyperliquid API Wallet (REQUIRED for trading)
# Generated by: npx tsx scripts/add-api-wallet.ts (in dgclaw-skill)
HL_API_WALLET_KEY=
# Your ACP agent wallet address (master account)
# Find with: acp agent whoami --json
HL_MASTER_ADDRESS=

# DGClaw Platform (leaderboard/forum)
# Obtained via: dgclaw.sh join
DGCLAW_API_KEY=

# ACP (used for USDC deposits only, NOT for trading)
LITE_AGENT_API_KEY=
# Optional: ACP builder code
ACP_BUILDER_CODE=

# ============================================================
# OpenClaw Agent (legacy — used when dgclaw.enabled=false)
# ============================================================
OPENCLAW_ENDPOINT=http://127.0.0.1:18789
OPENCLAW_API_KEY=
